---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE, FIELD_LABEL } from '../../consts';
import { GUIDE_TOOLS } from '../../guide-tools';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, all: guides },
  }));
}

const { entry, all } = Astro.props;
const data = entry.data;
const { Content } = await render(entry);

const fieldLabel = FIELD_LABEL[data.field] ?? '가이드';
const url = `${SITE.url}/guides/${entry.id}/`;
const tools = GUIDE_TOOLS[data.field] ?? [];

// 관련 글 (h1 조회)
const relatedEntries = (data.related ?? [])
  .map((slug) => all.find((g) => g.id === slug))
  .filter((g): g is NonNullable<typeof g> => Boolean(g));

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: data.h1,
  description: data.description,
  inLanguage: 'ko',
  datePublished: data.publishedAt,
  dateModified: data.updatedAt,
  mainEntityOfPage: url,
  author: { '@type': 'Organization', name: data.author },
  publisher: { '@type': 'Organization', name: SITE.name, url: SITE.url },
};
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: '홈', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: '절차 가이드', item: `${SITE.url}/guides/` },
    { '@type': 'ListItem', position: 3, name: fieldLabel, item: `${SITE.url}/guides/#${data.field}` },
    { '@type': 'ListItem', position: 4, name: data.h1, item: url },
  ],
};
---

<BaseLayout
  title={data.title}
  description={data.description}
  canonical={`/guides/${entry.id}/`}
  ogType="article"
  jsonld={[articleLd, breadcrumbLd]}
>
  <section class="section">
    <div class="wrap wrap-narrow">
      <p class="breadcrumb">
        <a href="/">홈</a> &rsaquo; <a href="/guides/">절차 가이드</a> &rsaquo;
        <a href={`/guides/#${data.field}`}>{fieldLabel}</a>
      </p>
      <article class="article">
        <p class="kicker">{data.kicker}</p>
        <h1>{data.h1}</h1>
        <p class="byline">
          <strong>{data.reviewer}</strong>
          {data.readingTime && <> · {data.readingTime}</>}
          · 최종 검토일 {data.lastVerifiedAt}
        </p>

        <div class="prose">
          <Content />

          {
            data.sources.length > 0 && (
              <div class="source-panel">
                <h2>출처</h2>
                <ul>
                  {data.sources.map((s) => (
                    <li>
                      <span class="src-issuer">{s.issuer}</span>
                      {s.url ? <a href={s.url} target="_blank" rel="noopener">{s.title}</a> : <span>{s.title}</span>}
                    </li>
                  ))}
                </ul>
                <p class="src-note">
                  이 글은 위 공식 자료를 바탕으로 작성했으며, 최종 검토일은 {data.lastVerifiedAt}입니다.
                  법령·판례는 개정될 수 있으니 중요한 결정 전 최신 내용을 확인하세요.
                </p>
              </div>
            )
          }

          {
            tools.length > 0 && (
              <div class="guide-tools no-print">
                <h3>이 주제에 쓸 수 있는 도구</h3>
                <div class="tool-links">
                  {tools.map((t) => (
                    <a href={t.href}>{t.label} &rsaquo;</a>
                  ))}
                  <a href={`/guides/#${data.field}`}>{fieldLabel} 절차 더보기 &rsaquo;</a>
                </div>
              </div>
            )
          }

          {
            relatedEntries.length > 0 && (
              <div class="related">
                <h2>함께 보면 좋은 글</h2>
                {relatedEntries.map((r) => (
                  <a href={`/guides/${r.id}/`}>{r.data.h1}</a>
                ))}
              </div>
            )
          }

          <div class="disclaimer">
            <strong>면책 안내</strong> — 이 글은 일반적인 법률 정보이며 특정 사건에 대한 법률
            자문이 아닙니다. 실제 요건·금액·기한은 개별 사정과 법령 개정에 따라 달라지므로,
            구체적인 판단은 변호사 등 전문가와 상담하시기 바랍니다. 무료 상담은
            대한법률구조공단(국번 없이 132)을 이용하실 수 있습니다.
          </div>
        </div>
      </article>
    </div>
  </section>
  <div class="wrap">
    <div class="ad-slot" aria-hidden="true">
      <div class="ph">광고 영역 (AdSense) — 승인 후 자동 노출</div>
    </div>
  </div>
</BaseLayout>
