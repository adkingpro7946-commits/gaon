---
import BaseLayout from '../layouts/BaseLayout.astro';
import body from '../_parts/index.body.html?raw';
import scriptJs from '../_parts/index.script.js?raw';
---

<BaseLayout title="가온(家穩) — 변호사를 부르기 전에, 스스로 할 수 있는 것부터" description="내용증명·지급명령·소액소송 서식 생성기와 인지대·퇴직금·상속·지연이자 계산기. 임대차·이혼·상속·노동·채권 등 8개 분야의 법률 절차를 스스로 해결하는 무료 도구 모음, 가온입니다." canonical="/">
  <Fragment set:html={body} />
  <script is:inline set:html={scriptJs}></script>
</BaseLayout>
